{
  "version": 2,
  "builds": [
    {
      "src": "api/check.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/check",
      "dest": "/api/check.js"
    },
    {
      "src": "/proposal.html",
      "dest": "/proposal.html"
    },
    {
      "src": "/",
      "dest": "/index.html"
    }
  ]
}
